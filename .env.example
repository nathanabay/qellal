# Qellal environment variables — copy to .env.local and fill in.
# .env.local is gitignored. NEVER commit real secrets.

# Supabase (EU/Frankfurt project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server/scrapers only — never expose to the browser

# Notifications — Telegram
TELEGRAM_BOT_TOKEN=              # BotFather token; used by the webhook + notify job
TELEGRAM_WEBHOOK_SECRET=        # set as secret_token when registering the webhook
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=  # e.g. QellalBot; powers the "Connect Telegram" link

# Notifications — email is sent via SMTP (SMTP_SSL) by scripts/notify.py.
# (There is no Resend/Brevo integration; use any SMTP provider, e.g. Brevo SMTP.)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=                       # From address; defaults to SMTP_USER if unset

# Absolute base URL of the app, used in notification links (tenders, unsubscribe).
APP_URL=http://localhost:3000

# Billing — Chapa payment gateway (server-only; never expose to the browser)
CHAPA_SECRET_KEY=               # Chapa secret key; enables checkout + verify
CHAPA_WEBHOOK_SECRET=           # required in production — webhook signature is
                                # enforced (rejected on mismatch) when this is set
