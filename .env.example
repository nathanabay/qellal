# Qellal environment variables — copy to .env.local and fill in.
# .env.local is gitignored. NEVER commit real secrets.

# Supabase (EU/Frankfurt project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server/scrapers only — never expose to the browser

# Notifications
TELEGRAM_BOT_TOKEN=
RESEND_API_KEY=              # or BREVO_API_KEY
